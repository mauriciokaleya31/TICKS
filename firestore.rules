rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Permitir leitura e escrita para que todas as operações funcionem perfeitamente
    // sem erros de permissão ou bloqueios durante o uso e teste do sistema.

    match /users/{userId} {
      allow read, write: if true;
    }

    match /events/{eventId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /coupons/{couponId} {
      allow read, write: if true;
    }

    match /reviews/{reviewId} {
      allow read, write: if true;
    }

    match /blogs/{blogId} {
      allow read, write: if true;
    }

    match /faqs/{faqId} {
      allow read, write: if true;
    }

    match /cms_configs/{configId} {
      allow read, write: if true;
    }
  }
}
